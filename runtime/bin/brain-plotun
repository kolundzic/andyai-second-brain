#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
case "${1:-help}" in
  help)
    echo "brain-plotun commands: status report export"
    ;;
  status)
    echo "$ROOT/brain/big-plotun/status/BIG_PLOTUN_01_STATUS.json"
    ;;
  report)
    echo "$ROOT/brain/reports/BIG_PLOTUN_01_REPORT.md"
    ;;
  export)
    echo "$ROOT/brain/big-plotun/exports/big-plotun-01-export.zip"
    ;;
  *)
    echo "Unknown command: $1"
    exit 1
    ;;
esac
