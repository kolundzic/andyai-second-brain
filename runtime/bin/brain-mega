#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
case "${1:-help}" in
  help)
    echo "brain-mega commands: status report export"
    ;;
  status)
    echo "$ROOT/brain/big-plotun-02/status/BIG_PLOTUN_02_STATUS.json"
    ;;
  report)
    echo "$ROOT/brain/reports/BIG_PLOTUN_02_REPORT.md"
    ;;
  export)
    echo "$ROOT/brain/big-plotun-02/exports/big-plotun-02-export.zip"
    ;;
  *)
    echo "Unknown command: $1"
    exit 1
    ;;
esac
